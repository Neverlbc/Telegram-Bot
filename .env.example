# ============================
# Telegram Bot 配置
# ============================

# Telegram Bot Token (从 @BotFather 获取)
BOT_TOKEN=your_bot_token_here

# Bot 运行模式: polling / webhook
BOT_MODE=polling

# ============================
# MySQL 数据库配置
# ============================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=bot_user
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=telegram_bot

# ============================
# Redis 配置
# ============================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================
# Webhook 配置 (生产环境)
# ============================
WEBHOOK_URL=https://bot.example.com/webhook
WEBHOOK_PORT=8443
WEBHOOK_SECRET=your_webhook_secret_here

# ============================
# 聚水潭 ERP 配置
# ============================
JUSHUITAN_APP_KEY=your_app_key
JUSHUITAN_APP_SECRET=your_app_secret

# ============================
# 跨运宝 (KYB) WMS 配置
# ============================
KYB_API_URL=https://open.imlb2c.com
KYB_APP_ID=your_app_id
KYB_APP_SECRET=your_app_secret
KYB_TOKEN=your_static_token
KYB_PREFER_STATIC_TOKEN=1
KYB_PLATFORM_CUSTOMER_CODE=your_platform_customer_code

# ============================
# 物流 API 配置
# ============================
CDEK_CLIENT_ID=your_cdek_client_id
CDEK_CLIENT_SECRET=your_cdek_client_secret
RUPOST_API_TOKEN=your_rupost_token
CAINIAO_APP_KEY=your_cainiao_key
CAINIAO_APP_SECRET=your_cainiao_secret

# ============================
# AI 自动回复配置
# ============================
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o-mini
AI_REPLY_MAX_COUNT=5
AI_REPLY_TTL_DAYS=7

# ============================
# 管理员与客服配置
# ============================
# 管理员 Telegram ID，逗号分隔
ADMIN_IDS=123456,789012
# 普通客服群组 Telegram ID
SUPPORT_GROUP_ID=-1001234567890
# 特定人工客服 Telegram ID (售后 AI 触发 5 次后转接)
ESCALATION_AGENT_ID=123456

# ── 售中下单 — 分类转接 ──
# 统一人工客服 Telegram 用户名 (不带@)
HUMAN_AGENT_USERNAME=ABFOfficialGroup
# Vandych 的帐篷专属客服 Telegram 用户名 (不带@)，留空则使用 HUMAN_AGENT_USERNAME
VANDYCH_AGENT_USERNAME=
# 动力工具速卖通店铺链接
ALIEXPRESS_STORE_URL=https://aliexpress.ru/store/1100115010
# Vandych 空运支付链接与折扣码；空运链接留空时会回退到 ALIEXPRESS_STORE_URL
# 若折扣表中存在 VANDYCH_SHIPPING_SKU 对应行，Bot 会优先使用表里的 Links/discount
ALIEXPRESS_SHIPPING_URL=https://aliexpress.ru/item/1005012163395302.html?gatewayAdapt=glo2rus&sku_id=12000057659415460
VANDYCH_SHIPPING_DISCOUNT_CODE=
VANDYCH_SHIPPING_SKU=BF-BCJ
VANDYCH_SHIPPING_SHEET_GID=1510817399

# ============================
# 隐藏入口密码
# ============================
VIP_INVENTORY_PASSWORD=ABFVIP2026Hunter
SERVICE_ADMIN_PASSWORD=service2026adminXXA
VANDYCH_PASSWORD=ABFVandych2026XXA

# ============================
# Google Sheets 配置
# ============================
GOOGLE_CREDENTIALS_FILE=google_credentials.json
OUTDOOR_SHEET_ID=your_outdoor_sheet_id
SERVICE_CENTER_SHEET_ID=your_service_center_sheet_id
DISCOUNT_SHEET_ID=1OgPkTP_1lqQnYC5yqc1c0bT7ixlTD8WUBe0PcAvyHEE
DISCOUNT_SHEET_GID=1376031396
# Outdoor SKU 映射（可选）：表格展示 SKU 与聚水潭/KYB SKU 不一致时配置
# OUTDOOR_SKU_ALIASES={"表格SKU":{"jst":["聚水潭SKU"],"kyb":["KYB SKU"]}}
OUTDOOR_SKU_ALIASES=

# ============================
# 日志配置
# ============================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================
# Analytics Dashboard 用户埋点看板
# ============================
# 浏览器访问：http://服务器IP:8088
# 如配置 TOKEN，网页里需要输入同一个 token 后才能读取数据
ANALYTICS_DASHBOARD_HOST=0.0.0.0
ANALYTICS_DASHBOARD_PORT=8088
ANALYTICS_DASHBOARD_TOKEN=
